{
  "version": 6,
  "cmakeMinimumRequired": {
    "major": 3,
    "minor": 27,
    "patch": 0
  },
  "configurePresets": [
    {
      "name": "base",
      "hidden": true,
      "cacheVariables": {
        "CMAKE_CONFIGURATION_TYPES": "Release;Debug;Coverage;RelWithChecks",
        "CMAKE_CXX_SCAN_FOR_MODULES": "Off",
        "CMAKE_CXX_STANDARD": "20",
        "DUNE_PYTHON_ALLOW_GET_PIP": "ON",
        "CMAKE_DISABLE_FIND_PACKAGE_MPI": "TRUE",
        "VCPKG_MANIFEST_FEATURES": "alberta;uggrid"
      },
      "environment": {
        "VCPKG_KEEP_ENV_VARS":
          "CCACHE_LOGFILE;CCACHE_DIR;CCACHE_DISABLE;CCACHE_NOHASHDIR;CCACHE_BASEDIR;CCACHE_MAXSIZE;CMAKE_CXX_COMPILER_LAUNCHER;CMAKE_C_COMPILER_LAUNCHER;$penv{VCPKG_KEEP_ENV_VARS}",
        "CCACHE_NOHASHDIR": "1"
      },
      "binaryDir": "${sourceDir}/build/${presetName}",
      "installDir": "${sourceDir}/build/${presetName}/install"
    },
    {
      "name": "clang_base",
      "hidden": true,
      "cacheVariables": {
        "CMAKE_CXX_COMPILER": "clang++",
        "CMAKE_CXX_FLAGS": "-Wall -Wextra -Wpedantic",
        "CMAKE_CXX_FLAGS_DEBUG": "-Og -g",
        "CMAKE_CXX_FLAGS_RELEASE": "-O3",
        "CMAKE_CXX_FLAGS_RELWITHCHECKS": "-O3 -g",
        "CMAKE_CXX_FLAGS_COVERAGE":
          "-Og -g -fcoverage-mcdc -fprofile-instr-generate -fcoverage-mapping"
      }
    },
    {
      "name": "gcc_base",
      "hidden": true,
      "cacheVariables": {
        "CMAKE_CXX_COMPILER": "g++",
        "CMAKE_CXX_FLAGS": "-Wall -Wextra -Wpedantic",
        "CMAKE_CXX_FLAGS_DEBUG": "-Og -g",
        "CMAKE_CXX_FLAGS_RELEASE": "-O3",
        "CMAKE_CXX_FLAGS_RELWITHCHECKS": "-O3 -g",
        "CMAKE_CXX_FLAGS_COVERAGE": "-Og -g -fprofile-arcs -ftest-coverage"
      }
    },
    {
      "name": "linux_base",
      "hidden": true,
      "inherits": [
        "base",
        "ninja"
      ],
      "condition": {
        "type": "equals",
        "lhs": "${hostSystemName}",
        "rhs": "Linux"
      }
    },
    {
      "name": "linux_clang",
      "hidden": false,
      "inherits": [
        "base",
        "ninja",
        "linux_base",
        "clang_base"
      ],
      "cacheVariables": {
        "VCPKG_TARGET_TRIPLET": "x64-linux-clang",
        "VCPKG_HOST_TRIPLET": "x64-linux-clang"
      },
      "displayName": "Clang"
    },
    {
      "name": "linux_gcc",
      "hidden": false,
      "inherits": [
        "base",
        "ninja",
        "linux_base",
        "gcc_base"
      ],
      "cacheVariables": {
        "VCPKG_TARGET_TRIPLET": "x64-linux-gcc",
        "VCPKG_HOST_TRIPLET": "x64-linux-gcc"
      },
      "displayName": "Gcc"
    },
    {
      "name": "linux_wheelbuilder",
      "binaryDir": "${sourceDir}/build/wheelbuilder",
      "installDir": "${sourceDir}/build/wheelbuilder/install",
      "hidden": false,
      "inherits": [
        "linux_gcc"
      ],
      "cacheVariables": {
        "VCPKG_MANIFEST_FEATURES": ""
      },
      "displayName": "Wheelbuilder"
    },
    {
      "name": "ninja",
      "hidden": true,
      "generator": "Ninja Multi-Config"
    },
    {
      "name": "win_clangcl",
      "binaryDir": "${sourceDir}/build/win_clangcl",
      "installDir": "${sourceDir}/build/win_clangcl/install",
      "hidden": false,
      "inherits": [
        "win_msvc"
      ],
      "generator": "Ninja Multi-Config",
      "cacheVariables": {
        "CMAKE_CXX_FLAGS_COVERAGE":
          "/EHsc /Od -fcoverage-mcdc -fprofile-instr-generate -fcoverage-mapping /DOASYS_CORE_ENABLE_CHECKS",
        "VCPKG_CHAINLOAD_TOOLCHAIN_FILE":
          "${sourceDir}/cmake/toolchains/msvc/Windows_Clang_toolchain.cmake",
        "VCPKG_TARGET_TRIPLET": "x64-clang-cl-static",
        "VCPKG_HOST_TRIPLET": "x64-clang-cl-static",
        "CMAKE_C_COMPILER_FRONTEND_VARIANT": "MSVC",
        "CMAKE_CXX_COMPILER_FRONTEND_VARIANT": "MSVC",
        "BUILD_SHARED_LIBS": "OFF"
      },
      "displayName": "Clangcl"
    },
    {
      "name": "win_msvc",
      "binaryDir": "${sourceDir}/build/win_msvc",
      "installDir": "${sourceDir}/build/win_msvc/install",
      "hidden": false,
      "inherits": [
        "windows_base"
      ],
      "generator": "Ninja Multi-Config",
      "cacheVariables": {
        "CMAKE_CXX_FLAGS": "/W3 /bigobj",
        "CMAKE_CXX_FLAGS_DEBUG": "/EHsc /Z7 /Od  /DOASYS_CORE_ENABLE_CHECKS",
        "CMAKE_CXX_FLAGS_RELEASE": "/EHsc /O2",
        "CMAKE_CXX_FLAGS_RELWITHCHECKS":
          "/EHsc /O2 /Z7 /DOASYS_CORE_ENABLE_CHECKS",
        "CMAKE_CXX_FLAGS_COVERAGE":
          "/EHsc /Od /PROFILE  /DOASYS_CORE_ENABLE_CHECKS",
        "CMAKE_MAP_IMPORTED_CONFIG_RELWITHCHECKS": "Release",
        "CMAKE_MAP_IMPORTED_CONFIG_COVERAGE": "Release",
        "VCPKG_TARGET_TRIPLET": "x64-msvc-static",
        "VCPKG_HOST_TRIPLET": "x64-msvc-static",
        "VCPKG_CHAINLOAD_TOOLCHAIN_FILE":
          "${sourceDir}/cmake/toolchains/msvc/Windows_MSVC_toolchain.cmake",
        "BUILD_SHARED_LIBS": "ON"
      },
      "displayName": "Msvc"
    },
    {
      "name": "win_wheelbuilder",
      "binaryDir": "${sourceDir}/build/wheelbuilder",
      "installDir": "${sourceDir}/build/wheelbuilder/install",
      "hidden": false,
      "inherits": [
        "win_msvc"
      ],
      "cacheVariables": {
        "VCPKG_MANIFEST_FEATURES": ""
      },
      "displayName": "Wheelbuilder"
    },
    {
      "name": "windows_base",
      "hidden": true,
      "inherits": [
        "base"
      ],
      "condition": {
        "type": "matches",
        "string": "${hostSystemName}",
        "regex": "Windows|CYGWIN.*|MSYS.*"
      }
    }
  ]
}
